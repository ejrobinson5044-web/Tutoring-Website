generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  student
  teacher
  parent
}

enum Mode {
  home
  classroom
}

enum AgeBand {
  fourteen_eighteen
}

model User {
  id       String   @id @default(cuid())
  email    String   @unique
  role     Role
  mode     Mode
  ageBand  AgeBand  @default(fourteen_eighteen)
  classes  Class[]  @relation("TeacherClasses")
  enrolled Enrollment[]
  attempts Attempt[]
  reflections Reflection[]
  skillSnapshots SkillSnapshot[]
}

model Class {
  id       String   @id @default(cuid())
  name     String
  joinCode String   @unique
  teacher  User     @relation("TeacherClasses", fields: [teacherId], references: [id])
  teacherId String
  enrollments Enrollment[]
  assignments Assignment[]
}

model Enrollment {
  id        String @id @default(cuid())
  class     Class  @relation(fields: [classId], references: [id])
  classId   String
  student   User   @relation(fields: [studentId], references: [id])
  studentId String
}

model Game {
  id    String @id
  name  String
  levels LevelConfig[]
}

model LevelConfig {
  id         String @id
  game       Game   @relation(fields: [gameId], references: [id])
  gameId     String
  configJson Json
}

model Assignment {
  id         String   @id @default(cuid())
  class      Class    @relation(fields: [classId], references: [id])
  classId    String
  game       Game     @relation(fields: [gameId], references: [id])
  gameId     String
  levelRange String
  dueDate    DateTime
  targetSkill String
  attempts   Attempt[]
}

model Attempt {
  id       String   @id @default(cuid())
  user     User     @relation(fields: [userId], references: [id])
  userId   String
  game     Game     @relation(fields: [gameId], references: [id])
  gameId   String
  levelId  String
  score    Int
  metrics  Json
  duration Int
  createdAt DateTime @default(now())
  reflection Reflection?
}

model SkillSnapshot {
  id          String @id @default(cuid())
  user        User   @relation(fields: [userId], references: [id])
  userId      String
  skillId     String
  rollingScore Float
  updatedAt    DateTime @updatedAt
}

model Reflection {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  attempt   Attempt  @relation(fields: [attemptId], references: [id])
  attemptId String
  text      String
  isSharedWithTeacher Boolean @default(false)
}
